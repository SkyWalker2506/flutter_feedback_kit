{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["github", "git", "atlassian", "flutter-dev", "context7", "jcodemunch"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "flutter analyze && flutter test",
            "async": true,
            "timeout": 300,
            "statusMessage": "Running flutter analyze & test..."
          }
        ]
      }
    ]
  }
}
